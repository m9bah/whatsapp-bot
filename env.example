# Green API credentials
# Found at: https://console.green-api.com → your instance
GREEN_API_INSTANCE=your_instance_id_here
GREEN_API_TOKEN=your_api_token_here

# Google Gemini API Key
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Your WhatsApp group chat ID
# Format: 120363XXXXXXXXX@g.us
# Find it by sending a test message and checking the webhook payload log
TARGET_GROUP_CHAT_ID=120363XXXXXXXXX@g.us

# Server port (optional, defaults to 3000)
PORT=3000
